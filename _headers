/*
  X-Content-Type-Options: nosniff

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/partners.html
  Cache-Control: no-cache, no-store, must-revalidate

# Media files - short cache with revalidation for development
/images/*
  Cache-Control: public, max-age=300, must-revalidate

/public/images/*
  Cache-Control: public, max-age=300, must-revalidate

/*.mp4
  Cache-Control: public, max-age=300, must-revalidate

/*.jpg
  Cache-Control: public, max-age=300, must-revalidate

/*.png
  Cache-Control: public, max-age=300, must-revalidate

/*.webp
  Cache-Control: public, max-age=300, must-revalidate

# JS modules — versioned via ?v=hash, cache with revalidation
/js/core/*
  Cache-Control: public, max-age=600, must-revalidate

/js/data/*
  Cache-Control: public, max-age=600, must-revalidate

/js/modules/*
  Cache-Control: public, max-age=600, must-revalidate

/js/agents/*
  Cache-Control: public, max-age=600, must-revalidate

/js/steps/*
  Cache-Control: public, max-age=600, must-revalidate

/js/utils/*
  Cache-Control: public, max-age=600, must-revalidate